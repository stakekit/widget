{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    /* Bundler mode */
    "allowImportingTsExtensions": true,
    "moduleDetection": "force",
    "tsBuildInfoFile": "dist/.tsbuildinfo/tsconfig.tsbuildinfo",

    /* Linting */
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
